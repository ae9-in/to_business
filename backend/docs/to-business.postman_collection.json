{
  "info": {
    "name": "To Businesses Backend",
    "_postman_id": "3b4de5d7-87e4-444b-925f-1c4d4b5dba80",
    "description": "Core CRM backend endpoints for the To Businesses module.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@tobusiness.local\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "Dashboard Summary",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/api/v1/dashboard/summary"
      }
    },
    {
      "name": "Create Shop",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/shops",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"shopName\": \"Metro Trade Hub\",\n  \"ownerName\": \"Rahul Das\",\n  \"businessType\": \"Distributor\",\n  \"addressLine1\": \"42 Business Park\",\n  \"area\": \"Salt Lake\",\n  \"city\": \"Kolkata\",\n  \"state\": \"West Bengal\",\n  \"pincode\": \"700091\",\n  \"phoneNumber1\": \"+919876543210\",\n  \"productCategory\": \"Beverages\"\n}"
        }
      }
    },
    {
      "name": "Create Delivery",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/api/v1/deliveries",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"shopId\": \"{{shopId}}\",\n  \"deliveryDate\": \"2026-03-20T00:00:00.000Z\",\n  \"productType\": \"Snack Combo Pack\",\n  \"quantity\": 40\n}"
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4001" },
    { "key": "accessToken", "value": "" },
    { "key": "shopId", "value": "" }
  ]
}
